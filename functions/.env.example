# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email Configuration
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EXPERT_EMAIL=expert@pismopro.pl

# Firebase Configuration (automatically provided by Firebase Functions)
# GOOGLE_APPLICATION_CREDENTIALS - automatically set by Firebase
# FIREBASE_CONFIG - automatically set by Firebase

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual Stripe keys
# 3. Get your Stripe keys from: https://dashboard.stripe.com/apikeys
# 4. Set up webhook endpoint in Stripe dashboard and get webhook secret
# 5. Deploy functions: firebase deploy --only functions