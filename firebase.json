{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**"
    ],
    "rewrites": [
          {
            "source": "/terms",
            "destination": "/terms.html"
          },
          {
            "source": "/privacy",
            "destination": "/privacy.html"
          },
          {
            "source": "**",
            "destination": "/test.html"
          }
        ]
  }
}