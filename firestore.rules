rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /orders/{orderId} {
      // Allow creation only if the data is valid and status is 'pending_payment'.
      // This prevents users from creating already 'paid' orders or submitting invalid data.
      allow create: if request.resource.data.status == 'pending_payment' &&
                       request.resource.data.customerEmail is string &&
                       request.resource.data.plan is string &&
                       request.resource.data.amount is number;

      // Allow read only while payment is pending.
      // Once the status changes (e.g., to 'paid'), the document is no longer readable by the client.
      // This protects customer data in completed orders.
      allow read: if resource.data.status == 'pending_payment';

      // Updates and deletes are only allowed from the backend (server-side functions).
      allow update, delete: if false;
    }
  }
}